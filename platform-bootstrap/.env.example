# =============================================================================
# Platform — Environment Variables Reference
# Copy this file to .env and fill in your values before running bootstrap.sh
# in NON_INTERACTIVE=true mode (CI/CD, repeated installs).
# =============================================================================

# ── Server & Domain ──────────────────────────────────────────────────────────
DOMAIN=platform.yourcompany.com
ADMIN_EMAIL=admin@yourcompany.com
PLATFORM_NAME=Platform

# ── Bootstrap behaviour ──────────────────────────────────────────────────────
# Set to true to skip all interactive prompts (CI mode)
NON_INTERACTIVE=false
# Set to true to skip Kubernetes install (use existing cluster)
SKIP_K8S=false
# Docker image tag to deploy
PLATFORM_IMAGE_TAG=latest
# Container registry URL for Platform images
PLATFORM_REPO_URL=ghcr.io/your-org/platform

# ── Components to install ────────────────────────────────────────────────────
INSTALL_ARGOCD=y
INSTALL_MONITORING=y
INSTALL_PORTAINER=y
INSTALL_INFISICAL=y
INSTALL_CERTMANAGER=y

# ── Let's Encrypt ────────────────────────────────────────────────────────────
LE_EMAIL=admin@yourcompany.com

# ── Generated Secrets (auto-filled by bootstrap.sh) ─────────────────────────
# These are generated by the script — leave blank unless you want specific values
POSTGRES_PASSWORD=
MONGO_PASSWORD=
REDIS_PASSWORD=
MINIO_ACCESS_KEY=platformadmin
MINIO_SECRET_KEY=
JWT_SECRET=
PLATFORM_WEBHOOK_SECRET=
ARGOCD_PASSWORD=
GRAFANA_PASSWORD=
INFISICAL_ENCRYPTION_KEY=
INFISICAL_JWT_SECRET=

# ── GitHub Integration ───────────────────────────────────────────────────────
# Personal Access Token with: repo, admin:org_hook, write:packages
GITHUB_TOKEN=
GITHUB_ORG=your-org
GITHUB_REGISTRY=ghcr.io
# Webhook URL after setup: https://DOMAIN/api/webhooks/github

# ── GitLab Integration ───────────────────────────────────────────────────────
GITLAB_URL=https://gitlab.com
# Personal Access Token with: api, read_repository
GITLAB_TOKEN=
GITLAB_GROUP=your-group
# Webhook URL after setup: https://DOMAIN/api/webhooks/gitlab

# ── ClickUp Integration ──────────────────────────────────────────────────────
# Found in: ClickUp → User Settings → Apps → Generate Token
CLICKUP_API_TOKEN=
# Found in workspace URL: app.clickup.com/TEAM_ID/...
CLICKUP_TEAM_ID=
# Default list for bug reports
CLICKUP_DEFAULT_LIST_ID=

# ── SMTP / Email Notifications ───────────────────────────────────────────────
# Provider: custom | ses | sendgrid | mailgun
SMTP_PROVIDER=
# Custom SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# AWS SES
SMTP_AWS_REGION=us-east-1
SMTP_AWS_KEY=
SMTP_AWS_SECRET=
# SendGrid
SENDGRID_API_KEY=
# Mailgun
MAILGUN_DOMAIN=
MAILGUN_API_KEY=
# From address (all providers)
SMTP_FROM_EMAIL=noreply@yourcompany.com
SMTP_FROM_NAME=Platform

# ── External S3 / Backup Storage (optional — MinIO used if blank) ────────────
EXT_S3_ENDPOINT=
EXT_S3_BUCKET=platform-backups
EXT_S3_KEY=
EXT_S3_SECRET=
EXT_S3_REGION=us-east-1

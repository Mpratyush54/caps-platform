{
  "name": "@mpratyush54/sdk-node",
  "version": "1.0.0",
  "description": "CAPS Platform Node.js SDK - Auto-registration, metrics, logging, config, storage, DB connections",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "jest --forceExit --detectOpenHandles",
    "test:unit": "jest --forceExit --detectOpenHandles --testPathPattern=tests/unit",
    "test:integration": "jest --forceExit --detectOpenHandles --testPathPattern=tests/integration",
    "test:coverage": "jest --coverage --forceExit --detectOpenHandles"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "ioredis": "^5.3.0",
    "mongoose": "^8.1.0",
    "pg": "^8.11.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^9.0.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5.3.0"
  },
  "files": ["dist"],
  "license": "MIT"
}

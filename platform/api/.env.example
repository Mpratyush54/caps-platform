# Platform API - Environment Variables

# PostgreSQL (Platform database)
PLATFORM_PG_HOST=localhost
PLATFORM_PG_PORT=5432
PLATFORM_PG_USER=platform
PLATFORM_PG_PASSWORD=your_password_here
PLATFORM_PG_DB=platform
PLATFORM_PG_POOL=10

# MongoDB (Logs, metrics, events)
PLATFORM_MONGO_URI=mongodb://localhost:27017/platform
PLATFORM_MONGO_POOL=5

# Redis (Caching, sessions)
PLATFORM_REDIS_HOST=localhost
PLATFORM_REDIS_PORT=6379
PLATFORM_REDIS_PASSWORD=
PLATFORM_REDIS_DB=0

# Kubernetes
# Path to kubeconfig file (default: ~/.kube/config)
KUBECONFIG=~/.kube/config

# Secrets encryption (master key for AES-256-GCM)
# Generate with: openssl rand -base64 32
SECRETS_ENCRYPTION_KEY=your-32-byte-base64-key-here

# GitLab
GITLAB_API_URL=https://gitlab.com/api/v4
GITLAB_TOKEN=your_gitlab_token_here

# ClickUp
CLICKUP_API_TOKEN=your_clickup_token_here

# Platform
PLATFORM_ENV=production
PLATFORM_URL=https://platform.148.113.58.205.sslip.io

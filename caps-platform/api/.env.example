# CAPS Platform API - Environment Variables

# PostgreSQL (Platform database)
CAPS_PG_HOST=localhost
CAPS_PG_PORT=5432
CAPS_PG_USER=caps
CAPS_PG_PASSWORD=your_password_here
CAPS_PG_DB=caps_platform
CAPS_PG_POOL=10

# MongoDB (Logs, metrics, events)
CAPS_MONGO_URI=mongodb://localhost:27017/caps_platform
CAPS_MONGO_POOL=5

# Redis (Caching, sessions)
CAPS_REDIS_HOST=localhost
CAPS_REDIS_PORT=6379
CAPS_REDIS_PASSWORD=
CAPS_REDIS_DB=0

# Kubernetes
# Path to kubeconfig file (default: ~/.kube/config)
KUBECONFIG=~/.kube/config

# Infisical (Secrets management)
INFISICAL_API_URL=https://app.infisical.com/api
INFISICAL_SERVICE_TOKEN=your_service_token_here

# GitLab
GITLAB_API_URL=https://gitlab.com/api/v4
GITLAB_TOKEN=your_gitlab_token_here

# ClickUp
CLICKUP_API_TOKEN=your_clickup_token_here

# Platform
CAPS_ENV=production
CAPS_PLATFORM_URL=https://platform.capskengeri.com
